# --- Firebase service account (Admin SDK) — powers the Firestore catalog ---
# Firebase project ID
FIREBASE_PROJECT_ID=
# Service-account private key (keep the literal \n escapes; wrap the value in quotes)
FIREBASE_PRIVATE_KEY=
# Service-account client email
FIREBASE_CLIENT_EMAIL=
# Storage bucket that hosts product images (e.g. your-project.appspot.com)
FIREBASE_STORAGE_BUCKET=

# --- Exchange rates (UAH-based) — converts stored UAH prices to USD for the en locale ---
# Rates API base URL (ExchangeRate-API v6 style; request path is <url>/<key>/latest/UAH)
EXCHANGE_RATE_API_URL=
# Rates API key
EXCHANGE_RATE_API_KEY=

# --- Checkout ---
# External order-relay service the checkout posts each order to
PLACE_ORDER_URL=
